# Vector DB Configuration
FAISS_INDEX_PATH=faiss_index

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM Configuration
LLM_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
LLM_MAX_TOKENS=300
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_DEVICE=-1

# PDF Processing
PDF_PATH=data/sample_pdfs/sample.pdf
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Retrieval
RETRIEVAL_K=3

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=enterprise-rag

# Logging
LOG_LEVEL=INFO
